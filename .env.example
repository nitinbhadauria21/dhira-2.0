# Dhira — environment variables
#
# HOW TO USE (plain English):
# 1. Copy this file to a new file called ".env.local"  (that file is git-ignored and safe for real keys).
# 2. Paste your real keys after the "=" signs.
# 3. Restart the dev server (npm run dev).
#
# Nothing here is required just to CLICK around the app — Dhira runs in a safe
# "offline" mode with a local data file when these are blank. Fill them in to
# switch on the real Claude brain and cloud saving.

# --- Dhira's AI brain (Anthropic Claude) ---
# Get this from https://console.anthropic.com  → API Keys → Create Key.
# Add a few dollars of credit under Billing. Keep it secret.
ANTHROPIC_API_KEY=

# --- Cloud database (Supabase) — optional ---
# From your Supabase project: Settings → API.
# If these are blank, Dhira saves to a local file (.data/) instead, which is
# perfect for a single-laptop demo.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# The service-role key is used only on the server. NEVER expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Proactive check-in endpoint protection ---
# A shared password so only your reminder tool (n8n) can trigger check-ins.
# Make up any long random string.
CHECKIN_SECRET=

# --- Notifications via Emergent (email + WhatsApp) ---
# Dhira writes a notification row then POSTs it to your Emergent workflow, which
# delivers via its own providers (Twilio/Gmail). Leave blank in dev/demo — then
# notifications are recorded and marked "sent" without an external provider.
EMERGENT_NOTIFY_WEBHOOK_URL=
EMERGENT_WEBHOOK_SECRET=
# Turn on WhatsApp only after your WhatsApp Business sender/template is approved.
WHATSAPP_ENABLED=false
# Public URL of this app (used so Emergent can call the delivery-status callback).
APP_URL=
